# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Base de données ────────────────────────────────────────────────────────────
# PostgreSQL (Supabase) — requis en production (Render + GitHub Actions)
# Format : postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Laisser vide en local pour utiliser SQLite automatiquement
DATABASE_URL=

# ── Binance ────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── LLM ────────────────────────────────────────────────────────────────────────
# Provider configuré dans config.json (gemini par défaut)
GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here   # si provider = claude

# ── Dashboard — Google OAuth2 ──────────────────────────────────────────────────
# Créer un OAuth2 Client ID : https://console.cloud.google.com/apis/credentials
# Type : "Web application"
# Authorized redirect URIs :
#   - http://localhost:5000/callback          (dev local)
#   - https://[ton-app].onrender.com/callback (Render)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── Dashboard — Accès ─────────────────────────────────────────────────────────
# Emails autorisés (séparés par des virgules) — vide = tous autorisés en local
ALLOWED_EMAILS=hugo.cambier@ornikar.com

# ── Dashboard — Session ───────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Sur Render : valeur générée automatiquement via render.yaml
SESSION_SECRET_KEY=
