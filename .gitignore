# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Virtual envs (Poetry manages its own, but just in case)
.venv/

# Runtime state (DB, LLM cache, agent/simulation state) — generated at runtime
logs/
data/

# Eval/learning artifacts — tracked except for the provider-specific LLM cache
# and the transient bench progress file (only useful mid-run, deleted on exit)
eval/llm_cache/
eval/reports/_progress.json

# Bench reports are scratch by default — commit milestones explicitly with
# `git add -f eval/reports/bench/<file>.json`. Already-tracked reports stay.
eval/reports/bench/

# macOS
.DS_Store

# Database
*.db
*.db-shm
*.db-wal

# Docker
.docker/

# GCP
.gcloud/

# Claude Code — user-local state ignored, project skills tracked
.claude/*
!.claude/skills/

# Trader-agent PR worktrees (transient)
.worktrees/
