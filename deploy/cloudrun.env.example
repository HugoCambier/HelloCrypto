# Secrets à créer dans GCP Secret Manager (deploy.sh le fait automatiquement depuis .env)
# Copie ce fichier en .env et remplis tes valeurs

# Binance (requis)
BINANCE_API_KEY=ta_cle_binance
BINANCE_API_SECRET=ton_secret_binance

# LLM — uniquement la clé du provider configuré dans config.json
GEMINI_API_KEY=ta_cle_gemini
# ANTHROPIC_API_KEY=ta_cle_claude   # si provider = claude

# Google OAuth2 (requis pour l'auth du dashboard)
# Crée un OAuth2 Client ID sur : https://console.cloud.google.com/apis/credentials
# Type : "Web application"
# Authorized redirect URIs : http://localhost:5000/callback  (+ l'URL Cloud Run après déploiement)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Local dev uniquement
# Liste d'emails autorisés (vide = tous autorisés en local)
ALLOWED_EMAILS=ton.email@gmail.com

# GCP (pour le dashboard en local pointant vers GCP)
# GCP_PROJECT=ton-projet-gcp
# GCP_REGION=europe-west9
