{
  "version": 2,
  "regions": ["cdg1"],
  "builds": [
    {
      "src": "dashboard/app.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "dashboard/app.py"
    }
  ]
}
